{
  "productName": "Focus Guard",
  "version": "0.1.0",
  "identifier": "com.focusguard.app",
  "build": {
    "frontendDist": "../desktop",
    "devUrl": null
  },
  "app": {
    "windows": [
      {
        "title": "Focus Guard",
        "width": 900,
        "height": 700,
        "resizable": true,
        "decorations": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
